<!-- Contact Form -->
<div class="contact-form">
  <h3>Send a Message</h3>
  <form id="contactForm" onsubmit="return sendEmail(event)" data-page-title="{{ page.title }}" data-page-url="{{ site.url }}{{ page.url }}">
    <div class="form-group">
      <label for="email">Your Email:</label>
      <input type="email" id="email" name="email" class="form-control" required>
    </div>
    <div class="form-group">
      <label for="name">Your Name:</label>
      <input type="text" id="name" name="name" class="form-control" required>
    </div>
    <div class="form-group">
      <label for="message">Message:</label>
      <textarea id="message" name="message" class="form-control" rows="4" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Send Message</button>
  </form>
</div>

<script>
function sendEmail(event) {
    event.preventDefault();
    
    var form = document.getElementById('contactForm');
    var email = document.getElementById('email').value;
    var name = document.getElementById('name').value;
    var message = document.getElementById('message').value;
    var pageTitle = form.getAttribute('data-page-title');
    var pageUrl = form.getAttribute('data-page-url');
    
    var mailtoLink = 'mailto:samik_mukhopadhyay@brown.edu'
        + '?subject=' + encodeURIComponent('Comment on: ' + pageTitle)
        + '&body=' + encodeURIComponent(
            'From: ' + name + ' (' + email + ')\n' 
            + 'Referring to: ' + pageUrl + '\n' 
            + '----------\n\n'
            + message 
        );
    
    window.location.href = mailtoLink;
    
    // Reset form after sending
    form.reset();
    return false;
}</script>

<style>
.contact-form {
    margin-top: 2rem;
    padding: 1.5rem;
    background-color: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color, rgba(0, 0, 0, 0.1));
    border-radius: 8px;
}

.contact-form h3 {
    margin-bottom: 1.5rem;
    color: var(--global-text-color);
}

.form-group {
    margin-bottom: 1rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--global-text-color-light);
}

.form-control {
    width: 100%;
    padding: 0.375rem 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--global-text-color);
    background-color: var(--global-bg-color);
    border: 1px solid var(--global-divider-color, rgba(0, 0, 0, 0.1));
    border-radius: 0.25rem;
    transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
}

.form-control:focus {
    border-color: var(--global-theme-color);
    outline: 0;
    box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--global-theme-color) 25%, transparent);
}

.btn-primary {
    color: var(--global-bg-color);
    background-color: var(--global-theme-color);
    border-color: var(--global-theme-color);
    padding: 0.375rem 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    border-radius: 0.25rem;
    cursor: pointer;
}

.btn-primary:hover {
    background-color: color-mix(in srgb, var(--global-theme-color) 85%, black);
    border-color: color-mix(in srgb, var(--global-theme-color) 80%, black);
}
</style>
